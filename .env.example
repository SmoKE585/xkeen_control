ROUTER_HOST=192.168.1.1
ROUTER_PORT=22
ROUTER_USER=root
ROUTER_PASSWORD=change_me

CMD_VPN_ON=xkeen -restart
CMD_VPN_OFF=xkeen -stop
CMD_STATUS=xkeen -status

XRAY_CONFIG_DIR=/opt/etc/xray/configs
STATUS_POLL_INTERVAL=180
VPN_RESTART_DELAY_SEC=3

NOTEPADPP_PATH=

CHECK_1_NAME=Прямое подключение
CHECK_1_URL=https://ya.ru
CHECK_1_EXPECTED=direct

CHECK_2_NAME=RU маршрут
CHECK_2_URL=https://www.youtube.com
CHECK_2_EXPECTED=RU

CHECK_3_NAME=NL маршрут
CHECK_3_URL=https://example.com
CHECK_3_EXPECTED=GE
